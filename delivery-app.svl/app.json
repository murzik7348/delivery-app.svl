{
  "expo": {
    "name": "delivery-app",
    "slug": "delivery-app",
    "version": "1.0.0",
    "scheme": "delivery-app",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.murzik7348.deliveryapp",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.murzik7348.deliveryapp",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAYVwd3Ckl9k_eOhrNd3vLfzHEa98897rw"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "expo-location"
    ],
    "extra": {
      "eas": {
        "projectId": "b083b897-3d46-4a68-9a38-3833f0cc568c"
      }
    }
  }
}
