{
  "expo": {
    "name": "K&M",
    "slug": "delivery-app",
    "version": "1.0.4",
    "scheme": "delivery-app",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0514"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.murzik7348.K-and-M",
      "googleServicesFile": "./GoogleService-Info.plist",
      "usesAppleSignIn": false,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "fetch"
        ],
        "NSLocationWhenInUseUsageDescription": "Додаток потребує доступу до геопозиції для показу вашої позиції на карті та вибору адреси доставки.",
        "NSPhotoLibraryUsageDescription": "Додаток потребує доступу до вашої галереї фото для вибору аватарки вашого профілю.",
        "NSCameraUsageDescription": "Додаток потребує доступу до вашої камери для створення фото профілю."
      }
    },
    "android": {
      "package": "delivery.andi.app",
      "versionCode": 6,
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAYVwd3Ckl9k_eOhrNd3vLfzHEa98897rw"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0a0514"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "edgeToEdgeLayoutEnabled": false
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          },
          "ios": {
            "useFrameworks": "static",
            "forceStaticLinking": [
              "RNFBApp",
              "RNFBAuth",
              "RNFBMessaging"
            ]
          }
        }
      ],
      "./plugins/withRNFirebaseStatic.js",
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "expo-location",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Додаток потребує доступу до вашої галереї фото для вибору аватарки вашого профілю.",
          "cameraPermission": "Додаток потребує доступу до вашої камери для створення фото профілю."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "b083b897-3d46-4a68-9a38-3833f0cc568c"
      }
    },
    "owner": "murzik7"
  }
}
