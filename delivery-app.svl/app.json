{
  "expo": {
    "name": "K&M",
    "slug": "delivery-app",
    "version": "1.0.0",
    "scheme": "delivery-app",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0514"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.murzik7348.K-and-M",
      "googleServicesFile": "./GoogleService-Info.plist",
      "usesAppleSignIn": false,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.murzik7348",
      "googleServicesFile": "./google-services.json",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyAYVwd3Ckl9k_eOhrNd3vLfzHEa98897rw"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0a0514"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "@react-native-firebase/app",
      "./plugins/withLiveActivity",
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          },
          "ios": {
            "useFrameworks": "static",
            "modularHeaders": true
          }
        }
      ],
      "./plugins/withRNFirebaseStatic.js",
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      "expo-location",
      "expo-notifications",
      "./plugins/withNoPushNotifications"
    ],
    "extra": {
      "eas": {
        "projectId": "b083b897-3d46-4a68-9a38-3833f0cc568c"
      }
    }
  }
}
